# =============================================================================
# CRM Nexa — Variáveis de ambiente
# =============================================================================
# Copie este arquivo para `.env` e preencha com valores reais.
# NUNCA commite o `.env` real (já está no .gitignore).
# =============================================================================

# --- Ambiente ---
NODE_ENV=development

# --- Database (Postgres 17 + pgvector) ---
# Usuário de aplicação (sem BYPASSRLS) — usado pela API em runtime
DATABASE_URL="postgresql://crm_app:CHANGE_ME@cloud.nexasource.com.br:52430/crm_nexa_dev?schema=public&sslmode=prefer"
# Usuário admin (com BYPASSRLS) — usado SOMENTE por migrations e jobs administrativos
DATABASE_ADMIN_URL="postgresql://crm_admin:CHANGE_ME@cloud.nexasource.com.br:52430/crm_nexa_dev?schema=public&sslmode=prefer"

# --- Redis ---
REDIS_URL="redis://default:CHANGE_ME@cloud.nexasource.com.br:52479"

# --- MinIO (S3-compatível) ---
S3_ENDPOINT="https://s3.nexasource.com.br"
S3_REGION="us-east-1"
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_BUCKET=crm-nexa-dev
S3_FORCE_PATH_STYLE=true

# --- Auth ---
# Gere com: openssl rand -hex 64
JWT_ACCESS_SECRET=CHANGE_ME_64_HEX_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_64_HEX_CHARS
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- API ---
API_PORT=3001
API_BASE_URL=http://localhost:3001

# --- Web ---
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=CHANGE_ME_64_HEX_CHARS

# --- RabbitMQ (será configurado em fase posterior) ---
# RABBITMQ_URL=amqp://...

# --- Provedores externos (configurados via UI por tenant — apenas defaults aqui) ---
# Nada por enquanto — credenciais ficam em `integrations` no banco
