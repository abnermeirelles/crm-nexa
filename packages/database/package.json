{
  "name": "@crm-nexa/database",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "prisma": {
    "seed": "dotenv -e ../../.env -- tsx src/seed.ts"
  },
  "scripts": {
    "db:format": "prisma format",
    "db:validate": "dotenv -e ../../.env -- prisma validate",
    "db:generate": "dotenv -e ../../.env -- prisma generate",
    "db:migrate:dev": "dotenv -e ../../.env -- prisma migrate dev",
    "db:migrate:create": "dotenv -e ../../.env -- prisma migrate dev --create-only",
    "db:migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:migrate:status": "dotenv -e ../../.env -- prisma migrate status",
    "db:migrate:reset": "dotenv -e ../../.env -- prisma migrate reset",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "db:seed": "dotenv -e ../../.env -- tsx src/seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@crm-nexa/shared": "workspace:*",
    "@prisma/client": "^6.0.0"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.4",
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
