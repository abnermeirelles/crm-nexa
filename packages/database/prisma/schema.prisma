// =====================================================================
// CRM Nexa — Schema Prisma
// =====================================================================
// Todas as mudanças no schema são versionadas via migrations:
//   pnpm -F @crm-nexa/database db:migrate:create -- --name <descricao>
// =====================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  // url usada por migrations e prisma CLI (role com BYPASSRLS).
  // O Prisma Client de runtime sobrescreve para DATABASE_URL (role crm_app, sujeita a RLS).
  url        = env("DATABASE_ADMIN_URL")
  // Extensões "trusted" gerenciadas pelo Prisma. A extensão `vector` (pgvector)
  // está instalada manualmente em crm_nexa_dev mas não é declarada aqui — será
  // adicionada na Fase 10 quando começarmos a usar embeddings de contatos.
  extensions = [uuidOssp(map: "uuid-ossp"), pgTrgm(map: "pg_trgm"), citext]
}

// =====================================================================
// Tenant — empresa cliente do SaaS
// =====================================================================
model Tenant {
  id        String    @id @default(uuid(7)) @db.Uuid
  slug      String    @unique @db.VarChar(64)
  name      String    @db.VarChar(255)
  plan      String    @default("starter") @db.VarChar(32)
  status    String    @default("active") @db.VarChar(32)
  limits    Json      @default("{}")
  dpoEmail  String?   @map("dpo_email") @db.VarChar(255)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  users          User[]
  sessions       UserSession[]
  auditLogs      AuditLog[]
  contacts       Contact[]
  contactImports ContactImport[]
  activities     Activity[]

  @@index([status])
  @@map("tenants")
}

// =====================================================================
// User — usuário do sistema (pertence a um tenant)
// =====================================================================
model User {
  id           String    @id @default(uuid(7)) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  email        String    @db.Citext
  passwordHash String    @map("password_hash")
  name         String    @db.VarChar(255)
  role         String    @default("agent") @db.VarChar(32)
  mfaSecret    String?   @map("mfa_secret")
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  sessions         UserSession[]
  auditLogs        AuditLog[]
  ownedContacts    Contact[]     @relation("ContactOwner")
  actedActivities  Activity[]    @relation("ActivityActor")

  @@unique([tenantId, email])
  @@index([tenantId, role])
  @@map("users")
}

// =====================================================================
// UserSession — refresh tokens ativos (1 linha por sessão de login)
// =====================================================================
model UserSession {
  id               String    @id @default(uuid(7)) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash")
  ip               String?   @db.Inet
  userAgent        String?   @map("user_agent")
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([userId, revokedAt])
  @@index([tenantId, expiresAt])
  @@map("user_sessions")
}

// =====================================================================
// AuditLog — registro append-only de ações sensíveis (LGPD)
// =====================================================================
model AuditLog {
  id         String   @id @default(uuid(7)) @db.Uuid
  tenantId   String?  @map("tenant_id") @db.Uuid
  actorType  String   @map("actor_type") @db.VarChar(32)
  actorId    String?  @map("actor_id") @db.Uuid
  action     String   @db.VarChar(64)
  entityType String?  @map("entity_type") @db.VarChar(32)
  entityId   String?  @map("entity_id") @db.Uuid
  before     Json?
  after      Json?
  ip         String?  @db.Inet
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actor  User?   @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([tenantId, action, createdAt])
  @@index([tenantId, entityType, entityId])
  @@map("audit_log")
}

// =====================================================================
// ContactStage — ciclo de vida do contato no funil
// =====================================================================
enum ContactStage {
  lead
  prospect
  customer
  churned

  @@map("contact_stage")
}

// =====================================================================
// Contact — pessoa ou empresa rastreada no CRM
// =====================================================================
model Contact {
  id          String       @id @default(uuid(7)) @db.Uuid
  tenantId    String       @map("tenant_id") @db.Uuid
  name        String       @db.VarChar(255)
  email       String?      @db.Citext
  phone       String?      @db.VarChar(32)
  // Apenas digitos (validacao de CPF/CNPJ via DTO; formato visual e responsabilidade da UI).
  document    String?      @db.VarChar(20)
  companyName String?      @map("company_name") @db.VarChar(255)
  stage       ContactStage @default(lead)
  source      String?      @db.VarChar(64)
  ownerId     String?      @map("owner_id") @db.Uuid
  tags        String[]     @default([])
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?    @map("deleted_at") @db.Timestamptz(6)

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  owner      User?      @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  activities Activity[]

  // Indexes adicionais (unique parcial em (tenantId, email) WHERE deletedAt IS NULL
  // e trigram em name) sao criados via SQL raw na migration — Prisma nao
  // expressa esses casos.
  @@index([tenantId, stage])
  @@index([tenantId, ownerId])
  @@map("contacts")
}

// =====================================================================
// ActivityType — categorias da timeline do contato
// =====================================================================
enum ActivityType {
  note
  call
  email
  meeting
  system

  @@map("activity_type")
}

// =====================================================================
// Activity — entrada na timeline de um contato (nota, call, system)
// =====================================================================
model Activity {
  id        String       @id @default(uuid(7)) @db.Uuid
  tenantId  String       @map("tenant_id") @db.Uuid
  contactId String       @map("contact_id") @db.Uuid
  type      ActivityType
  title     String?      @db.VarChar(255)
  body      String?
  // metadata livre por tipo: { phoneNumber, durationSec } para call,
  // { from, to } para stage change, etc.
  metadata  Json         @default("{}")
  actorId   String?      @map("actor_id") @db.Uuid
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime?    @map("deleted_at") @db.Timestamptz(6)

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Restrict)
  actor   User?   @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([tenantId, contactId, createdAt(sort: Desc)])
  @@index([tenantId, type])
  @@map("activities")
}

// =====================================================================
// ContactImportStatus — ciclo de vida do job de import CSV
// =====================================================================
enum ContactImportStatus {
  queued
  processing
  done
  failed

  @@map("contact_import_status")
}

// =====================================================================
// ContactImport — job de upload CSV de contatos
// =====================================================================
model ContactImport {
  id             String              @id @default(uuid(7)) @db.Uuid
  tenantId       String              @map("tenant_id") @db.Uuid
  createdBy      String              @map("created_by") @db.Uuid
  filename       String              @db.VarChar(255)
  status         ContactImportStatus @default(queued)
  totalRows      Int                 @default(0) @map("total_rows")
  processedRows  Int                 @default(0) @map("processed_rows")
  insertedRows   Int                 @default(0) @map("inserted_rows")
  updatedRows    Int                 @default(0) @map("updated_rows")
  errorRows      Int                 @default(0) @map("error_rows")
  errors         Json                @default("[]")
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  startedAt      DateTime?           @map("started_at") @db.Timestamptz(6)
  finishedAt     DateTime?           @map("finished_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId, createdAt])
  @@map("contact_imports")
}
