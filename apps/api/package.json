    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@node-rs/argon2": "^2.0.2",
    "bullmq": "^5.76.7",
    "class-transformer": "^0.5.1",
